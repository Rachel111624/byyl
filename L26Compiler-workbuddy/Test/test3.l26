{
    int a;
    int b;
    set s1;
    set s2;
    set s3;
    bool flag;

    a = 5;
    b = 3;
    s1 = {1, 2, 3, 4, 5};
    s2 = {3, 4, 5, 6, 7};

    s3 = s1 union s2;
    write s3;

    s3 = s1 inter s2;
    write s3;

    remove s1 3;
    write s1;

    flag = isempty(s1);
    write flag;

    if ((a > b) && (a != 0)) {
        write a;
    }
}