/*
  错误测试：集合使用非法关系运算符
  预期错误："集合只支持 == 与 !="
*/
{
    set s;
    set t;
    bool b;

    s = {1, 2, 3};
    t = {4, 5, 6};

    // 错误1：集合使用 < 比较
    b = s < t;        // ERROR: 集合只支持 == 与 !=

    // 错误2：集合使用 > 比较
    b = s > t;        // ERROR: 集合只支持 == 与 !=

    // 错误3：集合使用 <= 比较
    b = s <= t;       // ERROR: 集合只支持 == 与 !=

    // 错误4：集合使用 >= 比较
    b = s >= t;       // ERROR: 集合只支持 == 与 !=

    // 以下正常，不会报错
    b = s == t;       // OK
    b = s != t;       // OK
}
