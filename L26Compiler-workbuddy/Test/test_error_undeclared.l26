/*
  错误测试：未声明的变量
  预期错误："未声明的变量"
*/
{
    int x;

    x = 10;       // OK: x 已声明

    // 错误1：赋值时使用未声明变量
    x = y;        // ERROR: y 未声明

    // 错误2：运算中使用未声明变量
    x = z + 5;    // ERROR: z 未声明

    // 错误3：条件中使用未声明变量
    if (x > w) {  // ERROR: w 未声明
        x = 0;
    }

    // 错误4：write 未声明变量
    write u;      // ERROR: u 未声明
}
